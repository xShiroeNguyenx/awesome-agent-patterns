{
  "name": "awesome-agent-patterns",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "UI/UX pattern knowledge base for AI agents, served over MCP.",
  "workspaces": [
    "mcp-server",
    "demo"
  ],
  "scripts": {
    "build": "npm run build -w mcp-server",
    "build:server": "npm run build -w mcp-server",
    "build:demo": "npm run build -w demo",
    "dev:demo": "npm run dev -w demo",
    "build:index": "tsx scripts/build-index.ts",
    "check:integrity": "tsx scripts/check-integrity.ts",
    "check:render": "tsx scripts/render-check.ts",
    "check:types": "tsc -p tsconfig.patterns.json",
    "smoke": "node scripts/smoke-mcp.mjs",
    "smoke:published": "node scripts/smoke-published.mjs",
    "start": "node mcp-server/dist/index.js"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
